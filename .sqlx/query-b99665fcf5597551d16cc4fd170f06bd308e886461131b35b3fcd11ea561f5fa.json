  "query": "\n        UPDATE majors\n        SET\n            name = COALESCE($2, name),\n            code = COALESCE($3, code),\n            description = COALESCE($4, description),\n            sort_order = COALESCE($5, sort_order)\n        WHERE id = $1\n        RETURNING id, name, code, description, sort_order, created_at\n        ",
