  "query": "\n        SELECT c.id, c.title, c.description, c.cover_image_url, c.major_id,\n               c.teacher_id, u.real_name AS teacher_name,\n               c.status AS \"status: _\", c.created_at, c.updated_at,\n               c.vote_count\n        FROM courses c\n        LEFT JOIN users u ON u.id = c.teacher_id\n        WHERE c.id = $1\n        ",
