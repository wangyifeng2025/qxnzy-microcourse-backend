  "query": "\n        UPDATE chapters\n        SET\n            title       = COALESCE($2, title),\n            description = COALESCE($3, description),\n            sort_order  = COALESCE($4, sort_order),\n            updated_at  = NOW()\n        WHERE id = $1\n        RETURNING id, course_id, title, description, sort_order, created_at, updated_at\n        ",
